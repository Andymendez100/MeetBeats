# Google Meet URL to join
MEET_URL=https://meet.google.com/xxx-xxxx-xxx

# Google account email (for reference only — auth is handled via browser state)
GOOGLE_EMAIL=your-bot-account@gmail.com

# Bot settings
BOT_NAME=MeetBeats
COMMAND_PREFIX=!
DEFAULT_VOLUME=50

# Cache settings
CACHE_DIR=/tmp/meetbeats
MAX_CACHE_SIZE_MB=500
