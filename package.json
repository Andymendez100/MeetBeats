{
  "name": "meetbeats",
  "version": "1.0.0",
  "description": "Google Meet music bot — like a Discord music bot, but for Meet",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "setup-auth": "npx tsx scripts/setup-auth.ts",
    "docker:build": "docker compose -f docker/docker-compose.yml build",
    "docker:join": "docker compose -f docker/docker-compose.yml run --rm meetbeats",
    "docker:down": "docker compose -f docker/docker-compose.yml down"
  },
  "keywords": [
    "google-meet",
    "music-bot",
    "youtube"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "playwright": "^1.41.0",
    "winston": "^3.11.0"
  }
}
